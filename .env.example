NORTHGATE_ENVIRONMENT=development
NORTHGATE_LOG_LEVEL=INFO
NORTHGATE_HOST=0.0.0.0
NORTHGATE_PORT=8080
NORTHGATE_DATABASE_URL=postgresql+asyncpg://northgate:northgate@localhost:5433/northgate
NORTHGATE_REDIS_URL=redis://localhost:6380/0
NORTHGATE_ROUTING_SOURCE=configuration
NORTHGATE_USAGE_PERSISTENCE_ENABLED=false
NORTHGATE_GATEWAY_SLUG=default
NORTHGATE_ALLOWED_METADATA_KEYS=tenant_id,user_id,run_id,environment
NORTHGATE_REQUEST_LIMIT_PER_MINUTE=
NORTHGATE_CONCURRENCY_LIMIT=
NORTHGATE_TOKEN_LIMIT_PER_DAY=
